{% apply inline_css(source('style/emails.css')) %}
    <!DOCTYPE html>
    <html lang="fr">
    <head><meta charset="UTF-8"><title>Confirmation d'inscription</title></head>
    <body>
    <div class="email-wrapper">
        <div class="email-header">
            <h1>🍕 Pizzeria</h1>
            <p>Commande en ligne</p>
        </div>
        <div class="email-body">
            <h2>Bienvenue !</h2>
            <p>Votre compte a bien été créé avec l'adresse <strong>{{ email }}</strong>.</p>
            <p>Vous pouvez dès maintenant commander vos pizzas artisanales en ligne.</p>
            <div class="btn-wrapper">
                <a href="https://www.pizzeria.sebastien-petit.fr" class="btn">Commander maintenant</a>
            </div>
        </div>
        <div class="email-footer">
            <p>© 2026 Pizzeria — Tous droits réservés</p>
        </div>
    </div>
    </body>
    </html>
{% endapply %}
