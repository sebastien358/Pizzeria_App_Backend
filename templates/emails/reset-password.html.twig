{% apply inline_css(source('style/emails.css')) %}
    <!DOCTYPE html>
    <html lang="fr">
    <head><meta charset="UTF-8"><title>Réinitialisation du mot de passe</title></head>
    <body>
    <div class="email-wrapper">
        <div class="email-header">
            <h1>🍕 Pizzeria</h1>
            <p>Commande en ligne</p>
        </div>
        <div class="email-body">
            <p>Vous avez fait une demande de réinitialisation de mot de passe.</p>
            <p>Pour modifier votre mot de passe, veuillez cliquer sur le lien ci-dessous.</p>
            <div class="btn-wrapper">
                <a href="{{ url }}" class="btn">Modifier le mot de passe</a>
            </div>
        </div>
        <div class="email-footer">
            <p>© 2026 Pizzeria — Tous droits réservés</p>
        </div>
    </div>
    </body>
    </html>
{% endapply %}
