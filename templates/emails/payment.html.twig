{% apply inline_css(source('style/emails.css')) %}
    <!DOCTYPE html>
    <html lang="fr">
    <head><meta charset="UTF-8"><title>Confirmation de commande</title></head>
    <body>
    <div class="email-wrapper">
        <div class="email-header">
            <h1>🍕 Pizzeria</h1>
            <p>Commande en ligne</p>
        </div>
        <div class="email-body">
            <p>Bonjour {{ firstname }} {{ lastname }},</p>
            <p>Merci d'avoir passé commande chez nous !</p>
            <h2>Détails de votre commande :</h2>
            <ul>
                {% for item in commandItems %}
                    <li>{{ item.product.title }} (x{{ item.quantity }}) : {{ (item.price * item.quantity)|number_format(2, '.', ',') }} €</li>
                {% endfor %}
            </ul>
            <p>Montant total : {{ totalAmount|number_format(2, '.', ',') }} €</p>
            <p>Vous serez informé de l'avancement de votre commande par email.</p>
            <p>Merci pour votre confiance et à bientôt !</p>
        </div>
        <div class="email-footer">
            <p>© 2026 Pizzeria — Tous droits réservés</p>
        </div>
    </div>
    </body>
    </html>
{% endapply %}
